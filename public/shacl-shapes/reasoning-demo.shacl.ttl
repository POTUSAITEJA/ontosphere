@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://example.com/reasoning-demo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Shapes for the reasoning-demo ontology — demonstrates both Violations and Warnings.

# ── Violation: every Project must have a description ──────────────────────────
# projectAlpha has no rdfs:comment → produces sh:Violation (error)
<urn:shacl:demo:ProjectDescription>
  a sh:NodeShape ;
  sh:targetClass ex:Project ;
  sh:name "ProjectDescription" ;
  sh:property [
    sh:path rdfs:comment ;
    sh:minCount 1 ;
    sh:severity sh:Violation ;
    sh:message "Project must have an rdfs:comment description" ;
  ] .

# ── Violation: every Contractor must declare a manager ────────────────────────
# frank (Contractor) has no ex:hasSupervisor → produces sh:Violation (error)
<urn:shacl:demo:ContractorSupervisor>
  a sh:NodeShape ;
  sh:targetClass ex:Contractor ;
  sh:name "ContractorSupervisor" ;
  sh:property [
    sh:path ex:hasSupervisor ;
    sh:minCount 1 ;
    sh:severity sh:Violation ;
    sh:message "Contractor must have a designated supervisor (ex:hasSupervisor)" ;
  ] .

# ── Warning: employees should have a job title ────────────────────────────────
# Only alice and dave have ex:jobTitle → produces sh:Warning for bob, carol, eve
<urn:shacl:demo:EmployeeJobTitle>
  a sh:NodeShape ;
  sh:targetClass ex:Employee ;
  sh:name "EmployeeJobTitle" ;
  sh:property [
    sh:path ex:jobTitle ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "Employee should have an ex:jobTitle annotation" ;
  ] .

# ── Warning: named individuals should have rdfs:comment ───────────────────────
# None of the individuals have rdfs:comment → produces sh:Warning for all
<urn:shacl:demo:IndividualDocumentation>
  a sh:NodeShape ;
  sh:targetClass owl:NamedIndividual ;
  sh:name "IndividualDocumentation" ;
  sh:property [
    sh:path rdfs:comment ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "Named individual should have an rdfs:comment for documentation" ;
  ] .
