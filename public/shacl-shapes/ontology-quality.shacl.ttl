@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Ontology quality shapes: best-practice constraints for OWL ontologies

<urn:shacl:ontology-quality:ClassLabel>
  a sh:NodeShape ;
  sh:targetClass owl:Class ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "OWL class should have an rdfs:label" ;
  ] .

<urn:shacl:ontology-quality:ClassComment>
  a sh:NodeShape ;
  sh:targetClass owl:Class ;
  sh:property [
    sh:path rdfs:comment ;
    sh:minCount 1 ;
    sh:severity sh:Info ;
    sh:message "OWL class should have an rdfs:comment for documentation" ;
  ] .

<urn:shacl:ontology-quality:ObjectPropertyLabel>
  a sh:NodeShape ;
  sh:targetClass owl:ObjectProperty ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "Object property should have an rdfs:label" ;
  ] .

<urn:shacl:ontology-quality:ObjectPropertyDomain>
  a sh:NodeShape ;
  sh:targetClass owl:ObjectProperty ;
  sh:property [
    sh:path rdfs:domain ;
    sh:minCount 1 ;
    sh:severity sh:Info ;
    sh:message "Object property should declare rdfs:domain" ;
  ] .

<urn:shacl:ontology-quality:ObjectPropertyRange>
  a sh:NodeShape ;
  sh:targetClass owl:ObjectProperty ;
  sh:property [
    sh:path rdfs:range ;
    sh:minCount 1 ;
    sh:severity sh:Info ;
    sh:message "Object property should declare rdfs:range" ;
  ] .

<urn:shacl:ontology-quality:DatatypePropertyLabel>
  a sh:NodeShape ;
  sh:targetClass owl:DatatypeProperty ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "Datatype property should have an rdfs:label" ;
  ] .
