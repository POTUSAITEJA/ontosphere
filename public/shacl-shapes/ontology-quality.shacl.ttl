@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# ═══════════════════════════════════════════════════════════════════════
# Ontology quality shapes — best-practice constraints for OWL + SKOS
# ═══════════════════════════════════════════════════════════════════════

# ── owl:Class ─────────────────────────────────────────────────────────

<urn:shacl:ontology-quality:ClassLabel>
  a sh:NodeShape ;
  sh:target [
    a sh:SPARQLTarget ;
    sh:select "SELECT ?this WHERE { ?this a <http://www.w3.org/2002/07/owl#Class> . FILTER(isIRI(?this)) }" ;
  ] ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "OWL class should have an rdfs:label" ;
  ] .

<urn:shacl:ontology-quality:ClassComment>
  a sh:NodeShape ;
  sh:target [
    a sh:SPARQLTarget ;
    sh:select "SELECT ?this WHERE { ?this a <http://www.w3.org/2002/07/owl#Class> . FILTER(isIRI(?this)) }" ;
  ] ;
  sh:property [
    sh:path rdfs:comment ;
    sh:minCount 1 ;
    sh:severity sh:Info ;
    sh:message "OWL class should have an rdfs:comment for documentation" ;
  ] .

# ── owl:ObjectProperty ───────────────────────────────────────────────

<urn:shacl:ontology-quality:ObjectPropertyLabel>
  a sh:NodeShape ;
  sh:targetClass owl:ObjectProperty ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "Object property should have an rdfs:label" ;
  ] .

<urn:shacl:ontology-quality:ObjectPropertyDomain>
  a sh:NodeShape ;
  sh:targetClass owl:ObjectProperty ;
  sh:property [
    sh:path rdfs:domain ;
    sh:minCount 1 ;
    sh:severity sh:Info ;
    sh:message "Object property should declare rdfs:domain" ;
  ] .

<urn:shacl:ontology-quality:ObjectPropertyRange>
  a sh:NodeShape ;
  sh:targetClass owl:ObjectProperty ;
  sh:property [
    sh:path rdfs:range ;
    sh:minCount 1 ;
    sh:severity sh:Info ;
    sh:message "Object property should declare rdfs:range" ;
  ] .

# ── owl:DatatypeProperty ─────────────────────────────────────────────

<urn:shacl:ontology-quality:DatatypePropertyLabel>
  a sh:NodeShape ;
  sh:targetClass owl:DatatypeProperty ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "Datatype property should have an rdfs:label" ;
  ] .

# ── skos:Concept ─────────────────────────────────────────────────────

<urn:shacl:ontology-quality:ConceptPrefLabel>
  a sh:NodeShape ;
  sh:targetClass skos:Concept ;
  sh:property [
    sh:path skos:prefLabel ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "SKOS concept must have a skos:prefLabel" ;
  ] .

<urn:shacl:ontology-quality:ConceptInScheme>
  a sh:NodeShape ;
  sh:targetClass skos:Concept ;
  sh:property [
    sh:path skos:inScheme ;
    sh:minCount 1 ;
    sh:severity sh:Info ;
    sh:message "SKOS concept should be in a concept scheme (skos:inScheme)" ;
  ] .

# ── skos:ConceptScheme ───────────────────────────────────────────────

<urn:shacl:ontology-quality:ConceptSchemeLabel>
  a sh:NodeShape ;
  sh:targetClass skos:ConceptScheme ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:severity sh:Warning ;
    sh:message "SKOS concept scheme should have an rdfs:label" ;
  ] .
